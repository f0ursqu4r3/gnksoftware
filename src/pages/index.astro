---
import Layout from '../layouts/Layout.astro';
import gibson from '../assets/gibson.png';
import kyle from '../assets/kyle.png';
import { contactEmail, getServiceMailto, services } from '../data/services';

const signalPoints = [
	'Founder-led engineering, close to the code.',
	'Products, backends, automations, platforms, modernization, and recovery.',
	'Small-team delivery with visible technical decisions.',
];

const situations = [
	'The product needs senior implementation, not another planning cycle.',
	'The backend is carrying more business logic than the team can safely change.',
	'Operators are still moving critical data through spreadsheets and handoffs.',
	'An internal platform needs to match the real workflow instead of forcing workarounds.',
	'A legacy system still runs the business, but every change is expensive.',
	'A troubled build or production issue needs a clear technical read.',
];

const approach = [
	{
		title: 'Enter through the real system',
		body: 'We start with the code, data, workflows, users, constraints, and failure modes that define the work.',
	},
	{
		title: 'Find the first useful slice',
		body: 'We narrow the first milestone until it can prove behavior, reduce risk, or unblock the next decision.',
	},
	{
		title: 'Build with operating notes',
		body: 'We keep interfaces, deployment paths, ownership, and support behavior visible while the work is still being built.',
	},
	{
		title: 'Leave the system easier to own',
		body: 'The handoff is code, decisions, tests, and a path your team can reason about after we leave.',
	},
];

const capabilities = [
	'Product architecture',
	'API and service design',
	'Workflow applications',
	'Data validation',
	'Internal portals',
	'Background workers',
	'Legacy migration paths',
	'Production triage',
	'Operational handoff',
	'Observability',
	'Release planning',
	'Codebase assessment',
];

const serviceLinks = services.map((service) => ({
	...service,
	href: `/${service.slug}`,
}));

const directMailto = `mailto:${contactEmail}`;
---

<Layout
	title="G&K Software, LLC | Software work for systems with consequences"
	description="G&K Software is a founder-led development house for products, backend systems, automation, internal platforms, modernization, and technical rescue."
>
	<main class="min-h-screen bg-(--color-base) text-(--color-ink)">
		<header class="studio-nav sticky top-0 z-20">
			<div class="site-container flex flex-wrap items-center justify-between gap-4 py-4">
				<a class="flex items-center gap-3" href="/" aria-label="G&K Software home">
					<span class="wordmark-mark flex h-9 w-9 items-center justify-center text-sm font-extrabold">
						G&K
					</span>
					<span>
						<span class="block text-sm font-extrabold text-(--color-ink)">G&K Software</span>
						<span class="block text-xs font-medium text-(--color-ink-muted)">Development house</span>
					</span>
				</a>
				<nav class="flex w-full flex-wrap items-center gap-4 md:w-auto" aria-label="Homepage navigation">
					<a class="text-sm font-semibold text-(--color-ink-soft) hover:text-(--color-signal)" href="#services">Services</a>
					<details class="group relative basis-full md:basis-auto">
						<summary class="cursor-pointer list-none text-sm font-semibold text-(--color-ink-soft) hover:text-(--color-signal)">
							Practices
						</summary>
						<div class="studio-panel-solid mt-3 grid w-full gap-1 p-3 md:absolute md:right-0 md:w-72">
							{serviceLinks.map((service) => (
								<a class="px-2 py-1.5 text-sm font-semibold text-(--color-ink-soft) hover:text-(--color-signal)" href={service.href}>
									{service.navLabel}
								</a>
							))}
						</div>
					</details>
					<a class="text-sm font-semibold text-(--color-ink-soft) hover:text-(--color-signal)" href="#approach">Approach</a>
					<a class="text-sm font-semibold text-(--color-ink-soft) hover:text-(--color-signal)" href="#founders">Founders</a>
					<a class="text-sm font-semibold text-(--color-ink-soft) hover:text-(--color-signal)" href="#contact">Contact</a>
					<a
						class="studio-button studio-button-primary"
						href={directMailto}
					>
						Email G&K
					</a>
				</nav>
			</div>
		</header>

		<section class="synapse-field relative overflow-hidden bg-(--color-base) px-5 py-20 md:py-28" data-synapse-field>
			<canvas class="synapse-field-canvas" data-synapse-canvas aria-hidden="true"></canvas>
			<div class="site-container relative z-10 grid min-h-[34rem] items-end gap-10 md:grid-cols-[1.15fr,0.85fr]">
				<div class="flex flex-col justify-between gap-10">
					<div class="space-y-6">
						<p class="max-w-2xl text-sm font-semibold leading-7 text-(--color-signal)">
							Founder-led development for products, platforms, automations, and systems that need careful technical judgment.
						</p>
						<h1 class="text-balance max-w-5xl text-5xl font-extrabold leading-[0.98] tracking-[-0.025em] text-(--color-ink) md:text-7xl">
							Software work for systems with consequences.
						</h1>
						<p class="text-pretty max-w-3xl text-lg leading-8 text-(--color-ink-soft)">
							G&K Software is a small development house for teams that need senior builders close to the code. We build products,
							backends, automations, internal platforms, modernizations, and recoveries where failure has a real cost.
						</p>
					</div>
					<div class="flex flex-wrap gap-3">
						<a
							class="studio-button studio-button-primary"
							href="#services"
						>
							Review work lanes
						</a>
						<a
							class="studio-button studio-button-secondary"
							href={directMailto}
						>
							Send project context
						</a>
					</div>
				</div>

				<aside class="studio-panel p-5 md:p-6">
					<div class="flex items-start justify-between gap-6">
						<div>
							<p class="text-sm font-extrabold text-(--color-ink)">Work index</p>
							<p class="mt-2 text-sm leading-6 text-(--color-ink-muted)">Six entry points into the same operating model.</p>
						</div>
						<p class="text-sm font-extrabold text-(--color-signal)">06</p>
					</div>
					<div class="studio-divider-list mt-5">
						{serviceLinks.map((service) => (
							<a class="group flex items-center justify-between gap-4 py-3 text-sm font-bold text-(--color-ink-soft)" href={service.href}>
								<span class="group-hover:text-(--color-ink)">{service.title}</span>
								<span class="text-(--color-ink-muted) group-hover:text-(--color-signal)">View</span>
							</a>
						))}
					</div>
					<ul class="studio-divider-list mt-5 text-sm leading-6 text-(--color-ink-soft)">
						{signalPoints.map((point) => <li class="py-3">{point}</li>)}
					</ul>
				</aside>
			</div>
		</section>

		<section id="services" class="scroll-mt-32 bg-(--color-surface) px-5 section-pad md:scroll-mt-24">
			<div class="mx-auto max-w-6xl">
				<div class="mb-8 grid gap-4 md:grid-cols-[0.65fr,1.35fr]">
					<h2 class="text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">Work lanes</h2>
					<p class="max-w-3xl text-sm leading-7 text-(--color-ink-soft)">
						Each lane has a dedicated route with fit, deliverables, operating model, and typical project shapes. Pick the system
						pressure closest to what is in front of you.
					</p>
				</div>
				<div class="grid gap-4 md:grid-cols-2">
					{serviceLinks.map((service) => (
						<article class="studio-panel-solid flex min-h-72 flex-col gap-5 p-5 md:p-6">
							<div class="flex items-start justify-between gap-4">
								<h3 class="max-w-sm text-2xl font-extrabold tracking-[-0.02em] text-(--color-ink)">{service.title}</h3>
								<span class="studio-chip shrink-0 px-3 py-1 text-xs font-bold">
									{service.shortTitle}
								</span>
							</div>
							<p class="text-sm leading-7 text-(--color-ink-soft)">{service.summary}</p>
							<ul class="mt-auto grid gap-2 text-sm leading-6 text-(--color-ink-soft)">
								{service.homepageBullets.map((bullet) => (
									<li class="border-t border-(--color-line) pt-2">{bullet}</li>
								))}
							</ul>
							<div class="flex flex-wrap gap-3 border-t border-(--color-line) pt-4">
								<a class="studio-link text-sm" href={service.href}>
									View {service.shortTitle.toLowerCase()} work
								</a>
								<a class="text-sm font-bold text-(--color-ink-muted) no-underline hover:text-(--color-signal)" href={getServiceMailto(service)}>
									Email about {service.shortTitle.toLowerCase()}
								</a>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="bg-(--color-base) px-5 section-pad">
			<div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[0.7fr,1.3fr]">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">
						Pressure shows up in the system first.
					</h2>
				</div>
				<div class="grid gap-3 md:grid-cols-2">
					{situations.map((situation) => (
						<p class="border-t border-[rgba(196,206,183,0.1)] pt-4 text-sm leading-7 text-(--color-ink-soft)">{situation}</p>
					))}
				</div>
			</div>
		</section>

		<section id="approach" class="scroll-mt-32 bg-(--color-surface-soft) px-5 section-pad md:scroll-mt-24">
			<div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[0.7fr,1.3fr]">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">
						Small team, visible decisions.
					</h2>
				</div>
				<ol class="grid gap-4">
					{approach.map((item, index) => (
						<li class="studio-panel-solid grid gap-4 p-5 md:grid-cols-[5rem,1fr] md:p-6">
							<p class="text-sm font-extrabold text-(--color-signal)">{String(index + 1).padStart(2, '0')}</p>
							<div>
								<h3 class="text-xl font-extrabold text-(--color-ink)">{item.title}</h3>
								<p class="mt-2 text-sm leading-7 text-(--color-ink-soft)">{item.body}</p>
							</div>
						</li>
					))}
				</ol>
			</div>
		</section>

		<section class="border-b border-(--color-line) bg-(--color-base) px-5 py-12">
			<div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[0.7fr,1.3fr]">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">
						The technical surface area we cover.
					</h2>
				</div>
				<div class="flex flex-wrap gap-3">
					{capabilities.map((capability) => (
						<p class="studio-chip px-4 py-2 text-sm font-semibold">
							{capability}
						</p>
					))}
				</div>
			</div>
		</section>

		<section id="founders" class="scroll-mt-32 border-b border-(--color-line) bg-(--color-panel-muted) px-5 py-12 md:scroll-mt-24 md:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[0.7fr,1.3fr]">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">
						Builders stay in the room.
					</h2>
				</div>
				<div class="grid gap-5 md:grid-cols-2">
					<article class="studio-panel-solid grid gap-5 p-5 md:p-6">
						<img src={gibson.src} alt="Gibson Martin" class="h-28 w-28 rounded-[12px] object-cover" />
						<div>
							<h3 class="text-2xl font-extrabold text-(--color-ink)">Gibson Martin</h3>
							<p class="mt-2 text-sm leading-7 text-(--color-ink-soft)">
								Builder with public work across software systems, tooling, and technical experiments.
							</p>
							<a class="studio-link mt-4 inline-flex text-sm" href="https://github.com/wegfawefgawefg" rel="me noopener noreferrer" target="_blank">
								View Gibson Martin on GitHub
							</a>
						</div>
					</article>
					<article class="studio-panel-solid grid gap-5 p-5 md:p-6">
						<img src={kyle.src} alt="Kyle Dougan" class="h-28 w-28 rounded-[12px] object-cover" />
						<div>
							<h3 class="text-2xl font-extrabold text-(--color-ink)">Kyle Dougan</h3>
							<p class="mt-2 text-sm leading-7 text-(--color-ink-soft)">
								Builder with public work across applications, automation, developer tooling, and product infrastructure.
							</p>
							<a class="studio-link mt-4 inline-flex text-sm" href="https://github.com/f0ursqu4r3" rel="me noopener noreferrer" target="_blank">
								View Kyle Dougan on GitHub
							</a>
						</div>
					</article>
				</div>
			</div>
		</section>

		<section id="contact" class="scroll-mt-32 bg-(--color-base) px-5 py-12 md:scroll-mt-24 md:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[0.8fr,1.2fr]">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">
						Send the system context.
					</h2>
					<p class="mt-4 max-w-xl text-sm leading-7 text-(--color-ink-soft)">
						Send what is being built, what is unstable, the systems involved, the timeline, and what a useful first milestone would prove.
					</p>
				</div>
				<div class="studio-panel-solid grid gap-5 p-5 md:p-6">
					<div class="grid gap-3 text-sm leading-7 text-(--color-ink-soft) md:grid-cols-2">
						<div>
							<h3 class="font-extrabold text-(--color-ink)">Useful context</h3>
							<ul class="mt-2 grid gap-2">
								<li>What needs built, changed, or stabilized.</li>
								<li>Who uses it and what fails when it breaks.</li>
								<li>Code, data, integration, and deployment constraints.</li>
							</ul>
						</div>
						<div>
							<h3 class="font-extrabold text-(--color-ink)">Good first outcomes</h3>
							<ul class="mt-2 grid gap-2">
								<li>A scoped product slice or backend service.</li>
								<li>A system map, risk read, or recovery plan.</li>
								<li>A modernization or automation path your team can own.</li>
							</ul>
						</div>
					</div>
					<a class="studio-button studio-button-primary w-fit" href={directMailto}>
						Email {contactEmail}
					</a>
				</div>
			</div>
		</section>

		<footer class="border-t border-[rgba(196,206,183,0.1)] bg-(--color-base) px-5 py-10">
			<div class="mx-auto grid max-w-6xl gap-7 text-sm text-(--color-ink-soft) md:grid-cols-[1fr,1fr]">
				<div>
					<p class="font-extrabold text-(--color-ink)">G&K Software, LLC</p>
					<p class="mt-2 max-w-lg leading-7">
						Software work for products, platforms, automation, backend systems, modernization, and technical rescue.
					</p>
				</div>
				<nav class="grid gap-5 sm:grid-cols-2" aria-label="Footer navigation">
					<div>
						<p class="font-extrabold text-(--color-ink)">Homepage</p>
						<div class="mt-2 flex flex-wrap gap-3">
							<a class="hover:text-(--color-signal)" href="#services">Services</a>
							<a class="hover:text-(--color-signal)" href="#approach">Approach</a>
							<a class="hover:text-(--color-signal)" href="#founders">Founders</a>
							<a class="hover:text-(--color-signal)" href="#contact">Contact</a>
						</div>
					</div>
					<div>
						<p class="font-extrabold text-(--color-ink)">Practices</p>
						<div class="mt-2 flex flex-wrap gap-3">
							{serviceLinks.map((service) => (
								<a class="hover:text-(--color-signal)" href={service.href}>
									{service.shortTitle}
								</a>
							))}
						</div>
					</div>
				</nav>
			</div>
		</footer>
		<script src="../scripts/synapse-field.ts"></script>
	</main>
</Layout>
