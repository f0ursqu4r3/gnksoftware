---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import gibson from '../assets/gibson.png';
import kyle from '../assets/kyle.png';
import { contactEmail, services } from '../data/services';

const situations = [
	'The product needs senior implementation, not another planning cycle.',
	'The backend is carrying more business logic than the team can safely change.',
	'Operators are still moving critical data through spreadsheets and handoffs.',
	'An internal platform needs to match the real workflow instead of forcing workarounds.',
	'A legacy system still runs the business, but every change is expensive.',
	'A troubled build or production issue needs a clear technical read.',
];

const approach = [
	{
		title: 'Discovery',
		body: 'We read the current system, business pressure, users, risks, and constraints before prescribing work.',
	},
	{
		title: 'Scope',
		body: 'We turn the problem into a bounded first engagement with clear outcomes, tradeoffs, and ownership.',
	},
	{
		title: 'Delivery',
		body: 'We build in thin, reviewable slices so progress is visible and technical decisions stay close to the work.',
	},
	{
		title: 'Handoff',
		body: 'We leave behind code, decisions, tests, and operating notes your team can actually use.',
	},
];

const serviceLinks = services.map((service) => ({
	...service,
	href: `/${service.slug}`,
}));

const directMailto = `mailto:${contactEmail}`;
---

<Layout
	title="G&K Software, LLC | Software work for systems with consequences"
	description="G&K Software is a founder-led development house for products, backend systems, automation, internal platforms, modernization, and technical rescue."
>
	<main class="min-h-screen bg-(--color-base) text-(--color-ink)">
		<SiteHeader />

		<section class="synapse-field relative overflow-hidden bg-(--color-base) px-5 py-20 md:py-28" data-synapse-field>
			<canvas class="synapse-field-canvas" data-synapse-canvas aria-hidden="true"></canvas>
			<div class="site-container relative z-10 grid min-h-[34rem] items-end gap-10 md:grid-cols-[1.15fr,0.85fr]">
				<div class="flex flex-col justify-between gap-10">
					<div class="space-y-6">
						<p class="max-w-2xl text-sm font-semibold leading-7 text-(--color-signal)">
							Founder-led development for products, platforms, automations, and systems that need careful technical judgment.
						</p>
						<h1 class="text-balance max-w-5xl text-5xl font-extrabold leading-[0.98] tracking-[-0.025em] text-(--color-ink) md:text-7xl">
							High velocity. <span class="text-(--color-signal)">Senior engineering.</span> For systems with consequences.
						</h1>
						<p class="text-pretty max-w-3xl text-lg leading-8 text-(--color-ink-soft)">
							G&K Software is a small development house for teams that need senior engineers for serious code. We build for
							performance, durability, and places where failure has a real cost.
						</p>
					</div>
					<div class="flex flex-wrap gap-3">
						<a
							class="studio-button studio-button-secondary"
							href="#approach"
						>
							Our process
						</a>
						<a
							class="studio-button studio-button-primary"
							href={directMailto}
						>
							Contact us
						</a>
					</div>
				</div>

				<aside id="services" class="studio-panel scroll-mt-32 p-5 md:p-6" aria-label="Services">
					<div class="flex items-start justify-between gap-6">
						<div>
							<p class="text-sm font-extrabold text-(--color-ink)"><span class="text-(--color-signal)">Work</span> index</p>
							<p class="mt-2 text-sm leading-6 text-(--color-ink-muted)">Pick the pressure closest to what is in front of you.</p>
						</div>
					</div>
					<div class="studio-divider-list mt-5">
						{serviceLinks.map((service) => (
							<a class="group grid gap-1 py-3" href={service.href}>
								<span class="text-sm font-extrabold text-(--color-ink) group-hover:text-(--color-signal)">{service.title}</span>
								<span class="text-sm leading-6 text-(--color-ink-muted)">{service.summary}</span>
							</a>
						))}
					</div>
				</aside>
			</div>
		</section>

		<section class="bg-(--color-base) px-5 section-pad">
			<div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[0.7fr,1.3fr]">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">
						Pressure shows up in the system first.
					</h2>
				</div>
				<div class="studio-rail-list md:grid md:grid-cols-2 md:gap-x-8">
					{situations.map((situation) => (
						<p class="text-sm leading-7 text-(--color-ink-soft)">{situation}</p>
					))}
				</div>
			</div>
		</section>

		<section id="approach" class="scroll-mt-32 bg-(--color-surface-soft) px-5 section-pad md:scroll-mt-24">
			<div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[0.7fr,1.3fr]">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">
						From first read to shipped work.
					</h2>
				</div>
				<ol class="grid gap-0 overflow-hidden rounded-(--radius-md) border border-[rgba(196,206,183,0.1)] bg-(--color-surface)">
					{approach.map((item, index) => (
						<li class="grid gap-4 border-b border-[rgba(196,206,183,0.1)] p-5 last:border-b-0 md:grid-cols-[5rem,1fr] md:p-6">
							<p class="text-sm font-extrabold text-(--color-signal)" aria-hidden="true">{String(index + 1).padStart(2, '0')}</p>
							<div>
								<h3 class="text-xl font-extrabold text-(--color-ink)">{item.title}</h3>
								<p class="mt-2 text-sm leading-7 text-(--color-ink-soft)">{item.body}</p>
							</div>
						</li>
					))}
				</ol>
			</div>
		</section>

		<section id="founders" class="scroll-mt-32 border-b border-(--color-line) bg-(--color-panel-muted) px-5 py-12 md:scroll-mt-24 md:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[0.7fr,1.3fr]">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">
						Builders stay in the room.
					</h2>
				</div>
				<div class="grid gap-5 md:grid-cols-2">
					<article class="studio-panel-solid grid gap-5 p-5 md:p-6">
						<img src={gibson.src} alt="Gibson Martin" class="h-28 w-28 rounded-[12px] object-cover" />
						<div>
							<h3 class="text-2xl font-extrabold text-(--color-ink)">Gibson Martin</h3>
							<p class="mt-2 text-sm leading-7 text-(--color-ink-soft)">
								Builder with public work across software systems, tooling, and technical experiments.
							</p>
							<a class="studio-link mt-4 inline-flex text-sm" href="https://github.com/wegfawefgawefg" rel="me noopener noreferrer" target="_blank">
								View Gibson Martin on GitHub
							</a>
						</div>
					</article>
					<article class="studio-panel-solid grid gap-5 p-5 md:p-6">
						<img src={kyle.src} alt="Kyle Dougan" class="h-28 w-28 rounded-[12px] object-cover" />
						<div>
							<h3 class="text-2xl font-extrabold text-(--color-ink)">Kyle Dougan</h3>
							<p class="mt-2 text-sm leading-7 text-(--color-ink-soft)">
								Builder with public work across applications, automation, developer tooling, and product infrastructure.
							</p>
							<a class="studio-link mt-4 inline-flex text-sm" href="https://github.com/f0ursqu4r3" rel="me noopener noreferrer" target="_blank">
								View Kyle Dougan on GitHub
							</a>
						</div>
					</article>
				</div>
			</div>
		</section>

		<section id="contact" class="scroll-mt-32 bg-(--color-base) px-5 py-14 md:scroll-mt-24 md:py-20">
			<div class="studio-panel mx-auto flex max-w-6xl flex-col gap-6 p-6 md:flex-row md:items-center md:justify-between md:p-8">
				<div>
					<h2 class="text-balance text-3xl font-extrabold tracking-[-0.02em] text-(--color-ink) md:text-5xl">Ready to discuss work?</h2>
					<p class="mt-4 max-w-2xl text-sm leading-7 text-(--color-ink-soft)">
						Send a short note about what you need built, fixed, automated, or stabilized.
					</p>
				</div>
				<a class="studio-button studio-button-primary w-fit" href={directMailto}>
					Contact us
				</a>
			</div>
		</section>

		<SiteFooter />
		<script src="../scripts/synapse-field.ts"></script>
	</main>
</Layout>
