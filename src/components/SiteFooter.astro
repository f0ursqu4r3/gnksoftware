---
import { contactEmail } from '../data/services';

const directMailto = `mailto:${contactEmail}`;
---

<footer class="border-t border-[rgba(196,206,183,0.16)] bg-(--color-base) px-5 py-10">
	<div class="mx-auto flex max-w-6xl flex-col gap-6 text-sm text-(--color-ink-soft) md:flex-row md:items-start md:justify-between">
		<div>
			<p class="font-extrabold text-(--color-ink)">G&K Software, LLC</p>
			<p class="mt-2 max-w-lg leading-7">
				Software work for products, platforms, automation, backend systems, modernization, and technical rescue.
			</p>
		</div>
		<nav class="flex flex-wrap gap-x-5 gap-y-3" aria-label="Footer navigation">
			<a class="studio-footer-link" href="/#approach">Approach</a>
			<a class="studio-footer-link" href="/#founders">Founders</a>
			<a class="studio-footer-link" href="/#services">Services</a>
			<a class="studio-footer-link" href={directMailto}>Contact us</a>
		</nav>
	</div>
</footer>
