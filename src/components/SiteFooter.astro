---
import { contactEmail } from '../data/services';

const directMailto = `mailto:${contactEmail}`;
const footerLinkClass =
	'rounded-(--radius-sm) text-(--color-ink-soft) no-underline transition-colors duration-180 hover:text-(--color-signal) focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-(--color-signal) motion-reduce:transition-none';
---

<footer class="border-t border-[rgba(216,210,192,0.16)] bg-(--color-base) px-5 py-10">
	<div class="mx-auto flex max-w-6xl flex-col gap-6 text-sm text-(--color-ink-soft) md:flex-row md:items-start md:justify-between">
		<div>
			<p class="font-extrabold text-(--color-ink)">G&K Software, LLC</p>
			<p class="mt-2 max-w-lg leading-7">
				Software work for products, platforms, automation, backend systems, modernization, and technical rescue.
			</p>
		</div>
		<nav class="flex flex-wrap gap-x-5 gap-y-3" aria-label="Footer navigation">
			<a class={footerLinkClass} href="/#approach">Approach</a>
			<a class={footerLinkClass} href="/#founders">Founders</a>
			<a class={footerLinkClass} href="/#services">Services</a>
			<a class={footerLinkClass} href={directMailto}>Contact us</a>
		</nav>
	</div>
</footer>
