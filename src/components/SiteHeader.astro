---
import { contactEmail } from '../data/services';

const { homeHref = '/' } = Astro.props as { homeHref?: string };
const directMailto = `mailto:${contactEmail}`;
---

<header class="studio-nav sticky top-0 z-20">
	<div class="site-container flex items-center gap-3 py-3 md:justify-between md:gap-4 md:py-4">
		<a class="flex shrink-0 items-center gap-2.5 md:min-w-0 md:gap-3" href={homeHref} aria-label="G&K Software home">
			<span class="wordmark-mark flex h-8 w-8 shrink-0 items-center justify-center text-xs font-extrabold md:h-9 md:w-9 md:text-sm">
				G&K
			</span>
			<span class="hidden min-w-0 md:block">
				<span class="block truncate text-sm font-extrabold text-(--color-ink) md:text-sm">G&K Software</span>
				<span class="block truncate text-xs font-medium text-(--color-ink-muted)">Development house</span>
			</span>
		</a>
		<nav class="studio-nav-links" aria-label="Primary navigation">
			<a class="studio-nav-link" href="/">Home</a>
			<a class="studio-nav-link" href="/#approach">Approach</a>
			<a class="studio-nav-link" href="/#founders">Founders</a>
			<a class="studio-nav-link" href="/#services">Services</a>
			<a class="studio-button studio-button-primary site-header-cta" href={directMailto}>
				Contact us
			</a>
		</nav>
	</div>
</header>
