---
import { contactEmail } from '../data/services';

const { homeHref = '/' } = Astro.props as { homeHref?: string };
const directMailto = `mailto:${contactEmail}`;

const containerClass =
	'mx-auto flex w-[calc(100%-1.5rem)] max-w-[var(--container)] items-center gap-3 py-3 sm:w-[calc(100%-2rem)] md:justify-between md:gap-4 md:py-4';
const navLinkClass =
	'inline-flex min-h-[2.35rem] items-center whitespace-nowrap rounded-(--radius-sm) px-2 text-[0.78rem] font-bold text-(--color-ink-soft) no-underline transition-colors duration-180 hover:text-(--color-signal) focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-(--color-signal) min-[420px]:px-[0.62rem] min-[420px]:text-[0.8125rem] md:min-h-11 md:px-[0.7rem] md:text-sm md:hover:bg-[rgba(236,234,222,0.045)] motion-reduce:transition-none';
const headerCtaClass =
	'hidden min-h-11 items-center justify-center rounded-(--radius-sm) border border-transparent bg-(--color-signal) px-[1.15rem] py-3 text-sm font-extrabold text-(--color-base) no-underline transition-[background-color,color,translate] duration-180 hover:-translate-y-px hover:bg-(--color-ink) active:translate-y-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-(--color-signal) md:inline-flex motion-reduce:transition-none motion-reduce:hover:translate-y-0';
---

<header class="sticky top-0 z-20 border-b border-[rgba(216,210,192,0.1)] bg-[rgba(17,18,14,0.88)] backdrop-blur-[18px]">
	<div class={containerClass}>
		<a class="flex shrink-0 items-center gap-2.5 md:min-w-0 md:gap-3" href={homeHref} aria-label="G&K Software home">
			<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-(--radius-sm) bg-(--color-signal) text-xs font-extrabold text-(--color-base) [font-family:var(--font-display)] md:h-9 md:w-9 md:text-sm">
				G&K
			</span>
			<span class="hidden min-w-0 md:block">
				<span class="block truncate text-sm font-extrabold text-(--color-ink) md:text-sm">G&K Software</span>
				<span class="block truncate text-xs font-medium text-(--color-ink-muted)">Development house</span>
			</span>
		</a>
		<nav class="flex min-w-0 flex-1 items-center gap-[0.15rem] overflow-x-auto pb-[0.05rem] [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden md:gap-[0.35rem]" aria-label="Primary navigation">
			<a class={navLinkClass} href="/">Home</a>
			<a class={navLinkClass} href="/#approach">Approach</a>
			<a class={navLinkClass} href="/#founders">Founders</a>
			<a class={navLinkClass} href="/#services">Services</a>
			<a class={headerCtaClass} href={directMailto}>
				Contact us
			</a>
		</nav>
	</div>
</header>
