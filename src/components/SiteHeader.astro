---
import { contactEmail } from '../data/services';

const { homeHref = '/' } = Astro.props as { homeHref?: string };
const directMailto = `mailto:${contactEmail}`;
---

<header class="studio-nav sticky top-0 z-20">
	<div class="site-container flex flex-col items-stretch gap-3 py-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:py-4">
		<a class="flex min-w-0 items-center gap-3" href={homeHref} aria-label="G&K Software home">
			<span class="wordmark-mark flex h-9 w-9 shrink-0 items-center justify-center text-sm font-extrabold">
				G&K
			</span>
			<span class="min-w-0">
				<span class="block truncate text-sm font-extrabold text-(--color-ink)">G&K Software</span>
				<span class="block truncate text-xs font-medium text-(--color-ink-muted)">Development house</span>
			</span>
		</a>
		<nav class="studio-nav-links" aria-label="Primary navigation">
			<a class="studio-nav-link" href="/">Home</a>
			<a class="studio-nav-link" href="/#approach">Approach</a>
			<a class="studio-nav-link" href="/#founders">Founders</a>
			<a class="studio-nav-link" href="/#services">Services</a>
			<a class="studio-button studio-button-primary" href={directMailto}>
				Contact us
			</a>
		</nav>
	</div>
</header>
